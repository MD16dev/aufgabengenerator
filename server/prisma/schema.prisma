datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String       @id @default(uuid())
  username     String       @unique
  passwordHash String
  displayName  String?
  isAdmin      Boolean      @default(false)
  profilePic   String?      // Will store base64 data URI
  createdAt    DateTime     @default(now())
  solvedTasks  SolvedTask[]
  // Duel ratings (Elo) — one per module plus a general rating
  elo          Int          @default(1000)
  eloLinAlg    Int          @default(1000)
  eloOs        Int          @default(1000)
  eloFormalSys Int          @default(1000)
  eloAlgoStruct Int         @default(1000)
  duelWins     Int          @default(0)
  duelLosses   Int          @default(0)
  duels        DuelParticipant[]
  examAttempts ExamAttempt[]
}

model TaskType {
  id          String       @id
  name        String
  module      String
  solvedTasks SolvedTask[]
}

model SolvedTask {
  id         String   @id @default(uuid())
  userId     String
  taskTypeId String
  solvedAt   DateTime @default(now())
  // How the task was resolved: "solved" (correct on first try) or "revealed" (solution shown).
  outcome    String   @default("solved")
  // Points awarded. Correct = 1; revealed = 0 (not counted toward the leaderboard).
  points     Int      @default(1)

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskType TaskType @relation(fields: [taskTypeId], references: [id], onDelete: Cascade)
}

model Feedback {
  id             String   @id @default(uuid())
  category       String   // "BUG" or "FEEDBACK"
  message        String
  email          String?  // Optional sender contact
  userId         String?
  githubIssueUrl String?  // Link to the created GitHub issue
  createdAt      DateTime @default(now())
}

model BusQuestion {
  id            String   @id @default(uuid())
  question      String
  correctAnswer String
  distractor1   String
  distractor2   String
  distractor3   String
  explanation   String?
  createdAt     DateTime @default(now())
}

// ---- Duelle (real-time duels) ----

model Duel {
  id          String           @id @default(uuid())
  mode        String           // e.g. "same_task"
  moduleId    String           // module the duel belongs to
  taskTypeId  String           // the task type both players solve
  limit       Int              // win limit: 3, 5 or 10 solved tasks
  status      String           @default("pending") // pending | active | finished | cancelled
  winnerId    String?
  loserId     String?
  createdAt   DateTime         @default(now())
  finishedAt  DateTime?
  participants DuelParticipant[]
  rounds      DuelRound[]
}

model DuelParticipant {
  id        String   @id @default(uuid())
  duelId    String
  userId    String
  score     Int      @default(0)
  eloBefore Int      @default(1000)
  eloAfter  Int?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  duel      Duel     @relation(fields: [duelId], references: [id], onDelete: Cascade)

  @@unique([duelId, userId])
}

model DuelRound {
  id        String   @id @default(uuid())
  duelId    String
  taskType  String
  taskData  String   // JSON-serialized TaskData shared by both players
  solvedBy  String?  // userId of the player who solved it first (optional)
  createdAt DateTime @default(now())
  duel      Duel     @relation(fields: [duelId], references: [id], onDelete: Cascade)
}

// ---- Prüfungsmodus (exam mode) ----

model ExamAttempt {
  id          String   @id @default(uuid())
  userId      String
  moduleId    String // lin_alg | algo_struct | os | formal_sys
  durationMin Int // chosen exam length in minutes (20..180)
  // Total achievable points across all tasks in the plan.
  maxPoints   Int      @default(0)
  // Points the user actually earned (sum of ExamTask.userPoints).
  earnedPoints Int     @default(0)
  // Percentage 0..100, persisted so the leaderboard is stable across table changes.
  scorePct    Float    @default(0)
  // Final grade per the German 1.0..5.0 grading table.
  grade       Float    @default(5.0)
  passed      Boolean  @default(false)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks       ExamTask[]

  @@index([moduleId, scorePct])
}

model ExamTask {
  id           String  @id @default(uuid())
  attemptId    String
  taskTypeId   String
  category     String // human-readable category label, e.g. "Determinanten"
  workloadMin  Int     // estimated working time for this task in minutes
  autoGraded   Boolean // true when the system can grade it (answer/choices present)
  maxPoints    Int     // points this task contributes to the exam total
  userPoints   Int     @default(0) // points the user earned (0..maxPoints)
  attempt      ExamAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  @@index([attemptId])
}
